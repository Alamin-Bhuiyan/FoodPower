# Copy to .env (next to docker-compose.yml) and fill in. Compose reads it automatically.

# SQL Server SA password — REQUIRED. Must be strong: 8+ chars incl. upper, lower,
# digit and symbol, or the mssql container refuses to start.
MSSQL_SA_PASSWORD=Your_Strong_P@ssw0rd

# JWT signing — change from any default before exposing the API.
JWT_SECRET=FoodPowerChangeMeToALongRandomSecretAtLeast32Chars
JWT_ISSUER=FoodPower
JWT_AUDIENCE=FoodPower

# Seeded admin account (created on first startup).
ADMIN_EMAIL=admin@foodpower.local
ADMIN_PASSWORD=ChangeMe123

# Gmail SMTP for OTP email. Use a Gmail App Password, not your account password.
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER_NAME=FoodPower
EMAIL_SENDER_ADDRESS=
EMAIL_SENDER_PASSWORD=
EMAIL_USE_SSL=true
