# Database (SQL Server). Full connection string takes priority over appsettings ConnectionStrings:Database.
DB_CONNECTION_STRING="Server=localhost;Database=foodpower;User Id=sa;Password=YourStrong!Password;Encrypt=False;TrustServerCertificate=True"

# JWT (optional overrides for AppSettings section)
JWT_SECRET=FoodPowerAuthorizationSigningKeyChangeMeInProduction0123456789!@#$
JWT_ISSUER=https://foodpower.example.com/
JWT_AUDIENCE=https://foodpower.example.com/

# SMTP email (OTP delivery)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER_NAME=FoodPower
EMAIL_SENDER_ADDRESS=foodpower@example.com
EMAIL_SENDER_PASSWORD=
EMAIL_USE_SSL=true

# Seed admin (created confirmed on startup if missing)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
